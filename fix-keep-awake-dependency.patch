From c29ffb35035c08492542781c28aa179f51b9e163 Mon Sep 17 00:00:00 2001
From: Z User <z@container>
Date: Tue, 23 Jun 2026 14:27:34 +0000
Subject: [PATCH] fix(deps): downgrade keep-awake to ^5.0.1 for Capacitor 6
 compatibility

BREAKING: @capacitor-community/keep-awake@6.0.0 requires @capacitor/core@>=7.0.0
but project uses Capacitor 6 (^6.2.0). Downgrade to ^5.0.1 which supports
Capacitor 6 peer dependency.

Fixes: npm install ERESOLVE error in CI build-apk workflow
Verified: npm install + npm run build both pass
---
 package-lock.json | 10 +++++-----
 package.json      |  2 +-
 2 files changed, 6 insertions(+), 6 deletions(-)

diff --git a/package-lock.json b/package-lock.json
index 1fbadf3..43dcc34 100644
--- a/package-lock.json
+++ b/package-lock.json
@@ -9,7 +9,7 @@
       "version": "1.0.0",
       "dependencies": {
         "@base-ui/react": "^1.5.0",
-        "@capacitor-community/keep-awake": "^6.0.0",
+        "@capacitor-community/keep-awake": "^5.0.1",
         "@capacitor/android": "^6.2.0",
         "@capacitor/app": "^6.0.0",
         "@capacitor/core": "^6.2.0",
@@ -612,12 +612,12 @@
       "license": "MIT"
     },
     "node_modules/@capacitor-community/keep-awake": {
-      "version": "6.0.0",
-      "resolved": "https://registry.npmjs.org/@capacitor-community/keep-awake/-/keep-awake-6.0.0.tgz",
-      "integrity": "sha512-oPsJ3AuLNkGeafWLFEEa2e6CmkoDuQI05Y2HaoTJuImA6DP94IqjYMytb0Xwr0ZohMJFlbuPqkbgfk7XHLKxJw==",
+      "version": "5.0.1",
+      "resolved": "https://registry.npmjs.org/@capacitor-community/keep-awake/-/keep-awake-5.0.1.tgz",
+      "integrity": "sha512-5ZeJ5DQE5Aa1NwzD1kKv8IkHoLwKhkGYlURWHh4/SDrug0KBaGocKuk1q1TAk1nsCs6ndbSsEvUt2LZDoPo9SQ==",
       "license": "MIT",
       "peerDependencies": {
-        "@capacitor/core": ">=7.0.0"
+        "@capacitor/core": "^6.0.0"
       }
     },
     "node_modules/@capacitor/android": {
diff --git a/package.json b/package.json
index 5c32976..1841f81 100644
--- a/package.json
+++ b/package.json
@@ -21,7 +21,7 @@
   },
   "dependencies": {
     "@base-ui/react": "^1.5.0",
-    "@capacitor-community/keep-awake": "^6.0.0",
+    "@capacitor-community/keep-awake": "^5.0.1",
     "@capacitor/android": "^6.2.0",
     "@capacitor/app": "^6.0.0",
     "@capacitor/core": "^6.2.0",
-- 
2.47.3

