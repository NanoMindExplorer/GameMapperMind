-          background: h.getBackgroundUrl(),
+          backgroundImage: h.getBackgroundUrl(),
+          backgroundSize: 'cover',
+          backgroundPosition: 'center',
           backgroundColor: '#0f172a'
         }}
         id="canvas-container"
