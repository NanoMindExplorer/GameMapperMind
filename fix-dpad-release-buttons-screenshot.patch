From 85f62a36ff0daae2ddb3883edc929f49ad5e4017 Mon Sep 17 00:00:00 2001
From: Z User <z@container>
Date: Tue, 23 Jun 2026 17:45:06 +0000
Subject: [PATCH] fix: dpad release, button detection fallback, screenshot data
 URL
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Three fixes:

BUG 1: D-pad buttons stay pressed (don't release)
Root cause: GamepadPlugin only emitted DPAD press (value=1) when HAT
axis moved, but never emitted release (value=0) when HAT returned to
center (0,0). D-pad stayed 'pressed' forever.

Fix: Added else branch that emits release (value=0) for all D-pad
directions when HAT axis is centered (between -0.5 and 0.5).

BUG 2: A/X/Y/B and RB/LB not detected when pressed
Root cause: Capacitor WebView may intercept KeyEvent before it reaches
Activity.dispatchKeyEvent. If WebView consumes the event, our handler
is never called.

Fix: Added onKeyDown() and onKeyUp() overrides in MainActivity as
fallback. These are called by the Android system if dispatchKeyEvent
returns false or if the WebView doesn't consume the event. Both
dispatchKeyEvent AND onKeyDown/onKeyUp now forward gamepad button
events to GamepadPlugin.

BUG 3: Screenshot upload not displaying
Root cause: URL.createObjectURL(file) creates a blob: URL which does
NOT work with CSS backgroundImage in Capacitor WebView (CSP blocks
blob: URLs in inline styles).

Fix: Use FileReader.readAsDataURL(file) instead — converts file to
data: URL (base64 encoded) which works with CSS backgroundImage in
Capacitor WebView.
---
 .../gamemappermind/GamepadPlugin.kt           | 23 +++++++++++-------
 .../gamemappermind/MainActivity.kt            | 24 +++++++++++++++++++
 src/components/ScreenshotBackground.tsx       |  9 +++++--
 3 files changed, 46 insertions(+), 10 deletions(-)

diff --git a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadPlugin.kt b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadPlugin.kt
index f9f6e2f..edb614a 100644
--- a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadPlugin.kt
+++ b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadPlugin.kt
@@ -53,11 +53,9 @@ class GamepadPlugin : Plugin() {
             val hatX = event.getAxisValue(MotionEvent.AXIS_HAT_X)
             val hatY = event.getAxisValue(MotionEvent.AXIS_HAT_Y)
             
-            // Also read trigger values (L2 = AXIS_BRAKE, R2 = AXIS_GAS)
             val l2Trigger = event.getAxisValue(MotionEvent.AXIS_BRAKE)
             val r2Trigger = event.getAxisValue(MotionEvent.AXIS_GAS)
 
-            // Emit legacy event
             val ret = JSObject()
             ret.put("type", "AXIS")
             ret.put("axisX", axisX)
@@ -69,24 +67,33 @@ class GamepadPlugin : Plugin() {
             ret.put("timestamp", event.eventTime)
             notifyListeners("gamepadEvent", ret)
 
-            // Emit on standard "onGamepadAxis" channel
-            // Array format: [lx, ly, rx, ry, l2, r2] — match what GamepadTester expects
-            // axisX/axisY = left stick, axisZ/axisRZ = right stick
-            // l2Trigger/r2Trigger = L2/R2 triggers (AXIS_BRAKE/GAS)
             val axes = floatArrayOf(axisX, axisY, axisZ, axisRZ, l2Trigger, r2Trigger)
             TouchInjectionPlugin.emitGamepadAxis(axes)
             
-            // Also emit D-pad as button events (HAT axis → button press)
-            // This fixes "D-pad detected as R2/L2" bug
+            // D-pad: emit press AND release
+            // HAT axis: -1.0 = up/left, 0 = centered, 1.0 = down/right
             if (hatY < -0.5f) {
                 TouchInjectionPlugin.emitGamepadButton("DPAD_UP", 1, 1.0f)
+                TouchInjectionPlugin.emitGamepadButton("DPAD_DOWN", 0, 0.0f)
             } else if (hatY > 0.5f) {
                 TouchInjectionPlugin.emitGamepadButton("DPAD_DOWN", 1, 1.0f)
+                TouchInjectionPlugin.emitGamepadButton("DPAD_UP", 0, 0.0f)
+            } else {
+                // HAT centered — release all D-pad buttons
+                TouchInjectionPlugin.emitGamepadButton("DPAD_UP", 0, 0.0f)
+                TouchInjectionPlugin.emitGamepadButton("DPAD_DOWN", 0, 0.0f)
             }
+            
             if (hatX < -0.5f) {
                 TouchInjectionPlugin.emitGamepadButton("DPAD_LEFT", 1, 1.0f)
+                TouchInjectionPlugin.emitGamepadButton("DPAD_RIGHT", 0, 0.0f)
             } else if (hatX > 0.5f) {
                 TouchInjectionPlugin.emitGamepadButton("DPAD_RIGHT", 1, 1.0f)
+                TouchInjectionPlugin.emitGamepadButton("DPAD_LEFT", 0, 0.0f)
+            } else {
+                // HAT centered — release all D-pad buttons
+                TouchInjectionPlugin.emitGamepadButton("DPAD_LEFT", 0, 0.0f)
+                TouchInjectionPlugin.emitGamepadButton("DPAD_RIGHT", 0, 0.0f)
             }
             return true
         }
diff --git a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/MainActivity.kt b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/MainActivity.kt
index 4138122..fafd88c 100644
--- a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/MainActivity.kt
+++ b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/MainActivity.kt
@@ -72,6 +72,30 @@ class MainActivity : BridgeActivity() {
         return super.dispatchKeyEvent(event)
     }
 
+    // BUG FIX: Also override onKeyDown/onKeyUp as fallback
+    // Capacitor WebView may intercept key events before dispatchKeyEvent.
+    // onKeyDown/onKeyUp are called by the system if dispatchKeyEvent returns false
+    // or if the WebView doesn't consume the event.
+    override fun onKeyDown(keyCode: Int, event: KeyEvent?): Boolean {
+        if (KeyEvent.isGamepadButton(keyCode) || keyCode == KeyEvent.KEYCODE_DPAD_UP ||
+            keyCode == KeyEvent.KEYCODE_DPAD_DOWN || keyCode == KeyEvent.KEYCODE_DPAD_LEFT ||
+            keyCode == KeyEvent.KEYCODE_DPAD_RIGHT) {
+            GamepadPlugin.instance?.handleKeyDown(keyCode, event)
+            return true
+        }
+        return super.onKeyDown(keyCode, event)
+    }
+
+    override fun onKeyUp(keyCode: Int, event: KeyEvent?): Boolean {
+        if (KeyEvent.isGamepadButton(keyCode) || keyCode == KeyEvent.KEYCODE_DPAD_UP ||
+            keyCode == KeyEvent.KEYCODE_DPAD_DOWN || keyCode == KeyEvent.KEYCODE_DPAD_LEFT ||
+            keyCode == KeyEvent.KEYCODE_DPAD_RIGHT) {
+            GamepadPlugin.instance?.handleKeyUp(keyCode, event)
+            return true
+        }
+        return super.onKeyUp(keyCode, event)
+    }
+
     override fun dispatchGenericMotionEvent(event: MotionEvent): Boolean {
         if ((event.source and InputDevice.SOURCE_GAMEPAD) != 0 ||
             (event.source and InputDevice.SOURCE_JOYSTICK) != 0 ||
diff --git a/src/components/ScreenshotBackground.tsx b/src/components/ScreenshotBackground.tsx
index 00fbfaf..67fd800 100644
--- a/src/components/ScreenshotBackground.tsx
+++ b/src/components/ScreenshotBackground.tsx
@@ -44,8 +44,13 @@ export default function ScreenshotBackground({ h, children }: { h: OverlayWysiwy
                   onChange={(e) => {
                     const file = e.target.files?.[0];
                     if (file) {
-                      const url = URL.createObjectURL(file);
-                      h.setCustomScreenshotUrl(url);
+                      // BUG FIX: Convert to data: URL (base64) instead of blob: URL
+                      // blob: URLs don't work with CSS backgroundImage in Capacitor WebView
+                      const reader = new FileReader();
+                      reader.onload = () => {
+                        h.setCustomScreenshotUrl(reader.result as string);
+                      };
+                      reader.readAsDataURL(file);
                     }
                   }}
                 />
