From 0d2825d0311d16f606b9bea785d909ed4923ad08 Mon Sep 17 00:00:00 2001
From: Z User <z@container>
Date: Tue, 23 Jun 2026 15:49:59 +0000
Subject: [PATCH] fix(kotlin): add overloaded handleButtonBatched 2-arg for
 compatibility

GamepadJniPlugin.handleButtonBatched has 3-arg signature:
  handleButtonBatched(gamepadIndex: Int, buttonName: String, isDown: Boolean)

But GamepadListenerService.kt calls it with 2-arg:
  handleButtonBatched(buttonName: String, isDown: Boolean)

This causes Kotlin compilation error: Type mismatch.

Fix: Add overloaded 2-arg version that delegates to 3-arg with
default gamepadIndex = 0. This makes BOTH signatures work without
modifying all call sites in GamepadListenerService.kt.

Verified: both 2-arg and 3-arg calls now compile.
---
 .../com/nanomindexplorer/gamemappermind/GamepadJniPlugin.kt  | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadJniPlugin.kt b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadJniPlugin.kt
index 1a4a18e..d01ab6a 100644
--- a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadJniPlugin.kt
+++ b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/GamepadJniPlugin.kt
@@ -42,4 +42,9 @@ object GamepadJniPlugin {
             NativeGamepadMapper.instance?.handleButton(gamepadIndex, buttonName, isDown)
         }
     }
+
+    // Overloaded 2-arg version for backward compatibility (default gamepadIndex = 0)
+    fun handleButtonBatched(buttonName: String, isDown: Boolean) {
+        handleButtonBatched(0, buttonName, isDown)
+    }
 }
