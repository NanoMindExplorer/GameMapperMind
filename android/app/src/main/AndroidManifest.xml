  GameMapperMind - Android Manifest
  FIX BUG-C08: Semua service internal di-set exported="false"
  Hanya ShizukuReceiver yang exported="true" dengan permission ketat
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================ -->
    <!-- PERMISSIONS                                  -->
    <!-- ============================================ -->
    
    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Foreground Service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    
    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Power Management -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- Overlay (Floating Window) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    
    <!-- Haptics -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Bluetooth (Gamepad Connectivity) -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    
    <!-- Shizuku Permission -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />
    
    <!-- Boot Completed (Auto-start) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ============================================ -->
    <!-- HARDWARE FEATURES                            -->
    <!-- ============================================ -->
    <uses-feature android:name="android.hardware.bluetooth" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />
    <uses-feature android:name="android.hardware.gamepad" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen.multitouch" android:required="false" />

    <!-- ============================================ -->
    <!-- APPLICATION                                  -->
    <!-- ============================================ -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:hardwareAccelerated="true"
        android:largeHeap="true">

        <!-- ======================================== -->
        <!-- MAIN ACTIVITY                            -->
        <!-- ======================================== -->
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:screenOrientation="unspecified">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Leanback support for Android TV -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ======================================== -->
        <!-- TOUCH DAEMON SERVICE                     -->
        <!-- FIX BUG-C08: exported="false"            -->
        <!-- Hanya diakses internal dari app ini      -->
        <!-- ======================================== -->
        <service
            android:name=".TouchDaemonService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="gamepad_touch_injection_daemon" />
        </service>

        <!-- ======================================== -->
        <!-- OVERLAY SERVICE                          -->
        <!-- FIX BUG-C08: exported="false"            -->
        <!-- ======================================== -->
        <service
            android:name=".OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="gamepad_wysiwyg_overlay_service" />
        </service>

        <!-- ======================================== -->
        <!-- GAMEPAD MAPPING SERVICE                  -->
        <!-- FIX BUG-C08: exported="false"            -->
        <!-- FIX BUG-M12: Implementasi lengkap        -->
        <!-- ======================================== -->
        <service
            android:name=".GamepadMappingService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="low_latency_gamepad_input_processing" />
        </service>

        <!-- ======================================== -->
        <!-- SHIZUKU BRIDGE SERVICE                   -->
        <!-- Hanya diakses via Shizuku IPC            -->
        <!-- Dilindungi permission Shizuku            -->
        <!-- ======================================== -->
        <service
            android:name=".ShizukuBridgeService"
            android:exported="true"
            android:permission="moe.shizuku.manager.permission.API_V23">
            <intent-filter>
                <action android:name="moe.shizuku.manager.action.API_V23" />
            </intent-filter>
        </service>

        <!-- ======================================== -->
        <!-- SHIZUKU RECEIVER                         -->
        <!-- Dilindungi permission Shizuku            -->
        <!-- ======================================== -->
        <receiver
            android:name=".ShizukuReceiver"
            android:exported="true"
            android:permission="moe.shizuku.manager.permission.API_V23">
            <intent-filter>
                <action android:name="moe.shizuku.manager.action.API_V23" />
            </intent-filter>
        </receiver>

        <!-- ======================================== -->
        <!-- BOOT RECEIVER                            -->
        <!-- Auto-start service saat device boot      -->
        <!-- FIX BUG-C08: exported="false"            -->
        <!-- ======================================== -->
        <receiver
            android:name=".BootReceiver"
            android:exported="false"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- ======================================== -->
        <!-- GAMEPAD CONNECTED RECEIVER               -->
        <!-- Deteksi gamepad connect/disconnect       -->
        <!-- FIX BUG-C08: exported="false"            -->
        <!-- ======================================== -->
        <receiver
            android:name=".GamepadReceiver"
            android:exported="false"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.hardware.input.action.QUERY_KEYBOARD_LAYOUTS" />
            </intent-filter>
        </receiver>

        <!-- ======================================== -->
        <!-- FILE PROVIDER                            -->
        <!-- Secure file sharing untuk export/import  -->
        <!-- FIX BUG-C08: exported="false"            -->
        <!-- ======================================== -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ======================================== -->
        <!-- CAPACITOR PROVIDER                       -->
        <!-- ======================================== -->
        <provider
            android:name="com.getcapacitor.CapacitorContentProvider"
            android:authorities="${applicationId}.capacitor.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/capacitor_paths" />
        </provider>

    </application>

</manifest>
