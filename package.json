{
  "name": "game-mappermind",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "prebuild": "rimraf dist && npm run lint",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/client/index.html')){console.error('FAIL: dist/client/index.html missing'); process.exit(1);} console.log('PASS: dist/client/index.html exists');\"",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint:server": "tsc --noEmit -p tsconfig.server.json",
    "lint": "tsc --noEmit && npm run lint:server",
    "eslint": "eslint src/ --ext .ts,.tsx",
    "cap:sync": "npx cap sync android",
    "cap:build": "npm run build && npx cap sync android",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor-community/keep-awake": "^5.0.1",
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/screen-orientation": "^6.0.2",
    "@capacitor/status-bar": "^6.0.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "puppeteer": "^25.2.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^1.6.0"
  }
}
