From 9f692751411e10520e36d11145815f918b260561 Mon Sep 17 00:00:00 2001
From: Z User <z@container>
Date: Tue, 23 Jun 2026 16:12:54 +0000
Subject: [PATCH] fix(critical): prevent Shizuku service death on app
 background
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

CRITICAL BUG: TouchDaemonService.destroy() called System.exit(0) which
kills the entire Shizuku user service process. This was triggered by
TouchInjectionPlugin.handleOnDestroy() every time the Activity was
destroyed (app backgrounded, orientation change, swipe-away).

Symptoms reported by user:
1. App disappears from Shizuku management after backgrounding
2. Gamepad not detected (service process dead)
3. Must re-bind Shizuku every time app is opened

Fix:
1. TouchDaemonService.destroy(): Remove System.exit(0), replace with
   proper cleanup (releaseAllPointers + stopStreamCommand). Let Shizuku
   handle process lifecycle naturally.
2. TouchInjectionPlugin.handleOnDestroy(): Do NOT destroy or unbind
   service on Activity destroy. The Shizuku user service should persist
   across Activity lifecycle changes. Service is only cleaned up when:
   - User explicitly clicks 'Stop Daemon' (unbindService)
   - App process is fully terminated
   - Shizuku itself is stopped

This is a critical fix for app usability — without this, the app is
unusable because Shizuku service dies every time user switches apps.
---
 .../gamemappermind/TouchDaemonService.kt      |  5 ++++-
 .../gamemappermind/TouchInjectionPlugin.kt    | 19 +++++++++----------
 2 files changed, 13 insertions(+), 11 deletions(-)

diff --git a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchDaemonService.kt b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchDaemonService.kt
index bd8eefa..0516121 100644
--- a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchDaemonService.kt
+++ b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchDaemonService.kt
@@ -118,7 +118,10 @@ class TouchDaemonService : ITouchService.Stub {
 
     override fun destroy() {
         releaseAllPointers()
-        System.exit(0)
+        stopStreamCommand()
+        // DO NOT call System.exit(0) — it kills the entire Shizuku user service process,
+        // causing the app to disappear from Shizuku management and gamepad detection to fail.
+        // The service will be cleaned up properly by Shizuku when unbound.
     }
 
     private val inputManager: InputManager? by lazy {
diff --git a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchInjectionPlugin.kt b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchInjectionPlugin.kt
index 584e30b..203c366 100644
--- a/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchInjectionPlugin.kt
+++ b/android/app/src/main/java/com/nanomindexplorer/gamemappermind/TouchInjectionPlugin.kt
@@ -84,16 +84,15 @@ class TouchInjectionPlugin : Plugin() {
 
     override fun handleOnDestroy() {
         Shizuku.removeRequestPermissionResultListener(permissionListener)
-        if (isBound) {
-            try {
-                touchService?.destroy()
-            } catch (e: Exception) {
-                // ignore
-            }
-            Shizuku.unbindUserService(USER_SERVICE_ARGS, serviceConnection, true)
-            touchService = null
-            isBound = false
-        }
+        // Do NOT destroy or unbind service on handleOnDestroy.
+        // handleOnDestroy is called when the Activity is destroyed (e.g., app backgrounded,
+        // orientation change, or swipe-away). If we destroy/unbind here, the Shizuku
+        // user service process dies and the app disappears from Shizuku management.
+        // The service should persist across Activity lifecycle changes.
+        // Service will be properly cleaned up when:
+        // 1. User explicitly clicks "Stop Daemon" (calls unbindService)
+        // 2. App is fully terminated (process death)
+        // 3. Shizuku itself is stopped
         super.handleOnDestroy()
     }
 
